{
  "cli": {
    "version": ">= 20.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "developmentClient": false,
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "ios-simulator": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "//": "No simulator / no internal flag => App Store distribution signing (required for TestFlight)."
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "//": "Fill these in for `eas submit` / TestFlight. appleTeamId is your Team ID; appleId is your Apple account email; ascAppId is the numeric App ID from App Store Connect (created when you make the app record).",
        "appleId": "REPLACE_WITH_YOUR_APPLE_ID_EMAIL",
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "89F8DQ79UH"
      }
    }
  }
}
