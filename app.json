{
  "expo": {
    "name": "Flexx Fireworks",
    "slug": "flexx-fireworks-app",
    "version": "1.0.4",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "flexxfireworksapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flexxfireworks",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.flexxfireworks",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": false,
          "supportsPictureInPicture": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon-512x512.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#208AEF"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "networkSecurityConfig": "./network-security-config.xml"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5ac8e8ed-93ac-4c56-bbc8-8c4734b30910"
      }
    }
  }
}
